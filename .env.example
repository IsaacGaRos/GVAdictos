# GVAdictos Configuration

# Database
# SQLite (default for local development):
# DATABASE_URL=sqlite:///./db/gvadictos.sqlite

# PostgreSQL (for production/cloud):
DATABASE_URL=postgresql://gvadictos:dev_password@localhost:5432/gvadictos_db

# OpenAI / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (F5)
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Drive (F6)
GOOGLE_CREDENTIALS_JSON={}
DRIVE_BACKUP_FOLDER_ID=...

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Logging
SQL_ECHO=false
