\par \pard\plain \s25\qj\widctlpar\tx283\tx709\tx1276\facenter\li0\ri0\lin0\rin0\fi425\sb0\sa340\ltrpar\strike0\expnd0\expndtw-2\i0\ulnone\ulc0\b0\dbch\af9\dbch\af12\afs24\accnone\charscalex100\loch\f4\fs22\lang3082{\cf2\expnd0\expndtw0\rtlch \ltrch\loch
